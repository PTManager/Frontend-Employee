<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/swap_list_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="대타요청"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- segmented chips -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chip_open"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_selected"
            android:text="지원 가능"
            android:textColor="@color/brand_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp" />

        <TextView
            android:id="@+id/chip_mine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_chip_outline"
            android:text="내 요청"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp" />

        <TextView
            android:id="@+id/chip_applied"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_chip_outline"
            android:text="내 지원"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/swap_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tv_swap_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:gravity="center"
                android:text="표시할 대타가 없습니다."
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
