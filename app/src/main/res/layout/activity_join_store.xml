<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/join_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="매장 참여"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- state: invite code input -->
    <LinearLayout
        android:id="@+id/state_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="초대 코드 입력"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="사장님에게 받은 6자리 코드를 입력하세요"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/input_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_input"
            android:hint="A1B2C3"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:gravity="center"
            android:inputType="textCapCharacters"
            android:paddingVertical="18dp" />

        <TextView
            android:id="@+id/btn_submit_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_btn_primary"
            android:text="참여 요청 보내기"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:foreground="?attr/selectableItemBackground" />
    </LinearLayout>

    <!-- state: waiting for approval -->
    <LinearLayout
        android:id="@+id/state_pending"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <View
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_circle_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="승인 대기 중"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="참여 요청을 보냈어요.\n사장님이 승인하면 알림으로 알려드릴게요."
            android:textColor="@color/text_tertiary"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

        <TextView
            android:id="@+id/btn_enter_app"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_btn_outline_gray"
            android:text="(데모) 승인됨 — 앱 시작하기"
            android:textColor="@color/brand_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="15dp"
            android:foreground="?attr/selectableItemBackground" />
    </LinearLayout>
</LinearLayout>
