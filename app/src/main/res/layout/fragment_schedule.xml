<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="스케줄"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- week strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="월" />
                <TextView style="@style/DayNum" android:text="1" />
            </LinearLayout>

            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="화" />
                <TextView style="@style/DayNum" android:text="2" />
            </LinearLayout>

            <LinearLayout
                style="@style/DayCell"
                android:background="@drawable/bg_day_selected">
                <TextView style="@style/DayLabel" android:text="수" android:textColor="#CFE0FF" />
                <TextView style="@style/DayNum" android:text="3" android:textColor="@color/white" />
            </LinearLayout>

            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="목" />
                <TextView style="@style/DayNum" android:text="4" />
            </LinearLayout>

            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="금" />
                <TextView style="@style/DayNum" android:text="5" />
            </LinearLayout>

            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="토" android:textColor="@color/weekend_red" />
                <TextView style="@style/DayNum" android:text="6" />
            </LinearLayout>

            <LinearLayout style="@style/DayCell">
                <TextView style="@style/DayLabel" android:text="일" android:textColor="@color/weekend_red" />
                <TextView style="@style/DayNum" android:text="7" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="12월 3일 수요일"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- my shift -->
        <LinearLayout
            android:id="@+id/item_my_shift"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:background="@drawable/bg_schedule_active"
            android:paddingStart="15dp"
            android:paddingEnd="12dp"
            android:paddingVertical="12dp"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:00 – 18:00"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="강남점 · 홀 · 함께 현우"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- other's shift -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:background="@drawable/bg_schedule_muted"
            android:paddingStart="15dp"
            android:paddingEnd="12dp"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18:00 – 22:00"
                android:textColor="#555555"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="지수 근무 (내 근무 아님)"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_dashed"
            android:text="+ 근무 가능 시간 등록"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="13dp"
            android:foreground="?attr/selectableItemBackground" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
