<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- greeting + role chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill"
                android:text="알바 ▾"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="11dp"
                android:paddingVertical="6dp" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp">

                <ImageView
                    android:id="@+id/btn_bell"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_bell"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="알림" />

                <View
                    android:id="@+id/bell_dot"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="7dp"
                    android:layout_marginEnd="7dp"
                    android:background="@drawable/bg_dot_red"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <!-- today work card -->
        <LinearLayout
            android:id="@+id/card_today"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:background="@drawable/bg_today_card"
            android:padding="18dp"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tv_today_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#D6E4FF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_today_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_today_with"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="#D6E4FF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btn_checkin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_btn_white"
                android:text="출근하기"
                android:textColor="@color/brand_blue"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:foreground="?attr/selectableItemBackground" />
        </LinearLayout>

        <!-- quick actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <TextView
                android:id="@+id/btn_sub_request"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_outline_gray"
                android:text="대타 요청"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingVertical="13dp"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/btn_all_schedule"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_btn_outline_gray"
                android:text="전체 스케줄"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingVertical="13dp"
                android:foreground="?attr/selectableItemBackground" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_swap_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_outline_gray"
            android:text="대타 목록 · 지원하기"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="13dp"
            android:foreground="?attr/selectableItemBackground" />

        <!-- notices -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text=""
            android:textColor="#444444"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="@color/text_hint"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
